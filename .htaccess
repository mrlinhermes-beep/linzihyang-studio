# Password Protection for linzihyang studio website
AuthType Basic
AuthName "Restricted Area"
AuthUserFile /share/Web/.htpasswd
Require valid-user

# Security Headers
Header always set X-Frame-Options SAMEORIGIN
Header always set X-Content-Type-Options nosniff
Header always set X-XSS-Protection "1; mode=block"

# Prevent directory listing
Options -Indexes

# Cache static files
<FilesMatch "\.(ico|pdf|jpg|jpeg|png|gif|svg|woff|woff2|ttf|eot)$">
    Header set Cache-Control "max-age=31536000, public"
</FilesMatch>

# Protect sensitive files
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Rewrite rules for routing
RewriteEngine On
RewriteBase /

# Handle existing files and directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route all other requests to index.php
RewriteRule ^(.*)$ index.php [L]
